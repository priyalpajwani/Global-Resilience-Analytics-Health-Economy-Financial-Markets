    <worksheet name='Relationship Between Pre-covid Immunization Coverage and Infant Mortality Disruption (2020 to 2022)'>
      <table>
        <view>
          <datasources>
            <datasource caption='Population-total' name='federated.1b3jylu1gvkamk1bgcgxg1it8502' />
          </datasources>
          <datasource-dependencies datasource='federated.1b3jylu1gvkamk1bgcgxg1it8502'>
            <column caption='pre covid immunisation' datatype='real' name='[Calculation_2483101929477615616]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(&#10;    IF [Year] = 2018 OR [Year] = 2019 THEN [Immunization, DPT (% of children ages 12-23 months)]&#10;END)' />
            </column>
            <column caption='pre covid hospital beds ' datatype='real' name='[Calculation_2483101929477705729]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(&#10;    IF [Year] = 2018 OR [Year] = 2019 THEN [Hospital beds (per 1,000 people)]&#10;END)' />
            </column>
            <column caption='covid infant mortality 2020-2022' datatype='real' name='[Calculation_2483101929844887569]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(&#10;    IF [Year] &gt;= 2020 AND [Year] &lt;= 2022 THEN [Mortality rate, infant (per 1,000 live births)]&#10;END)' />
            </column>
            <column caption='pre covid infant  mortality ' datatype='real' name='[Calculation_2483101929850216469]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(&#10;    IF [Year] = 2018 OR [Year] = 2019 THEN [Mortality rate, infant (per 1,000 live births)]&#10;END)' />
            </column>
            <column caption='infant mortality disruption (pre vs covid)' datatype='real' name='[Calculation_2483101929852846106]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_2483101929844887569] - [Calculation_2483101929850216469]' />
            </column>
            <column datatype='string' name='[Country Name]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column datatype='real' name='[Hospital beds (per 1,000 people)]' role='measure' type='quantitative' />
            <column datatype='real' name='[Immunization, DPT (% of children ages 12-23 months)]' role='measure' type='quantitative' />
            <column datatype='real' name='[Mortality rate, infant (per 1,000 live births)]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Year]' role='dimension' type='quantitative' />
            <column-instance column='[Country Name]' derivation='None' name='[none:Country Name:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_2483101929477615616]' derivation='User' name='[usr:Calculation_2483101929477615616:qk]' pivot='key' type='quantitative' />
